{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(./ecosystem/scripts/check-wip.sh:*)",
      "Bash(~/.claude/skills/azure-devops-repos/scripts/pr-merge-message.sh *)",
      "Bash(~/.claude/skills/azure-devops/scripts/ado-rest.sh --method GET *)",
      "Bash(~/.claude/skills/detect-convention/scripts/*.sh)",
      "Bash(~/.claude/skills/git-commit/scripts/*.sh *)",
      "Bash(~/.claude/skills/git-commit/scripts/*.sh)",
      "Bash(~/.claude/skills/git-push/scripts/*.sh *)",
      "Bash(~/.claude/skills/git-push/scripts/*.sh)",
      "Bash(~/.claude/skills/github-pr/scripts/*.sh)",
      "Bash(~/repos/@shellicar/ecosystem/scripts/*.sh *)",
      "Bash(~/repos/@shellicar/ecosystem/scripts/*.sh)",
      "Bash(az --version:*)",
      "Bash(az * --help *)",
      "Bash(az * --help)",
      "Bash(az * list *)",
      "Bash(az * query *)",
      "Bash(az * show *)",
      "Bash(az boards query *)",
      "Bash(az boards work-item relation add *)",
      "Bash(az boards work-item relation remove *)",
      "Bash(az boards work-item show *)",
      "Bash(az boards work-item update *)",
      "Bash(az rest --method get *)",
      "Bash(az version:*)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git remote -v)",
      "Bash(git rev-list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(mkdir -p *)",
      "Bash(pnpm audit:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm run type-check:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm why:*)",
      "Bash(test *)",
      "mcp__azure-devops__core_*",
      "mcp__azure-devops__pipelines_download_artifact",
      "mcp__azure-devops__pipelines_get_build_changes",
      "mcp__azure-devops__pipelines_get_build_definition_revisions",
      "mcp__azure-devops__pipelines_get_build_definitions",
      "mcp__azure-devops__pipelines_get_build_log_by_id",
      "mcp__azure-devops__pipelines_get_build_log",
      "mcp__azure-devops__pipelines_get_build_status",
      "mcp__azure-devops__pipelines_get_builds",
      "mcp__azure-devops__pipelines_get_run",
      "mcp__azure-devops__pipelines_list_artifacts",
      "mcp__azure-devops__pipelines_list_runs",
      "mcp__azure-devops__repo_get_branch_by_name",
      "mcp__azure-devops__repo_get_pull_request_by_id",
      "mcp__azure-devops__repo_get_repo_by_name_or_id",
      "mcp__azure-devops__repo_list_branches_by_repo",
      "mcp__azure-devops__repo_list_directory",
      "mcp__azure-devops__repo_list_my_branches_by_repo",
      "mcp__azure-devops__repo_list_pull_request_thread_comments",
      "mcp__azure-devops__repo_list_pull_request_threads",
      "mcp__azure-devops__repo_list_pull_requests_by_commits",
      "mcp__azure-devops__repo_list_pull_requests_by_repo_or_project",
      "mcp__azure-devops__repo_list_repos_by_project",
      "mcp__azure-devops__repo_search_commits",
      "mcp__azure-devops__search_*",
      "mcp__azure-devops__wiki_get_page_content",
      "mcp__azure-devops__wiki_get_page",
      "mcp__azure-devops__wiki_get_wiki",
      "mcp__azure-devops__wiki_list_pages",
      "mcp__azure-devops__wiki_list_wikis",
      "mcp__azure-devops__wit_create_work_item",
      "mcp__azure-devops__wit_get_query_results_by_id",
      "mcp__azure-devops__wit_get_query",
      "mcp__azure-devops__wit_get_work_item_type",
      "mcp__azure-devops__wit_get_work_item",
      "mcp__azure-devops__wit_get_work_items_batch_by_ids",
      "mcp__azure-devops__wit_get_work_items_for_iteration",
      "mcp__azure-devops__wit_link_work_item_to_pull_request",
      "mcp__azure-devops__wit_list_backlog_work_items",
      "mcp__azure-devops__wit_list_backlogs",
      "mcp__azure-devops__wit_list_work_item_comments",
      "mcp__azure-devops__wit_list_work_item_revisions",
      "mcp__azure-devops__wit_my_work_items",
      "mcp__azure-devops__wit_update_work_item",
      "mcp__azure-devops__wit_update_work_items_batch",
      "mcp__azure-devops__wit_work_item_unlink",
      "mcp__azure-devops__wit_work_items_link",
      "mcp__azure-devops__work_get_iteration_capacities",
      "mcp__azure-devops__work_get_team_capacity",
      "mcp__azure-devops__work_get_team_settings",
      "mcp__azure-devops__work_list_iterations",
      "mcp__azure-devops__work_list_team_iterations",
      "mcp__cclsp__get_diagnostics",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__ide__getDiagnostics",
      "Read(/var/folders/s9/*/T/tmp.*)",
      "Read(~/.claude/CLAUDE.md)",
      "Read(~/.claude/settings.json)",
      "Read(~/.claude/skills/**)",
      "WebFetch(domain:next.shadcn-svelte.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Bash(*--unsafe*)",
      "Bash(*\"System.Parent=[0-9]+\"*)",
      "Edit(.git)",
      "Edit(**/package.json)",
      "Edit(~/.bash_logout)",
      "Edit(~/.bash_profile)",
      "Edit(~/.bashrc)",
      "Edit(~/.claude/hooks)",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/skills/*/_scripts)",
      "Edit(~/.claude/skills/auto-approve-security)",
      "Edit(~/.gitconfig)",
      "Edit(~/.profile)",
      "Edit(~/.zshrc)",
      "mcp__azure-devops__repo_create_pull_request",
      "mcp__azure-devops__repo_update_pull_request",
      "mcp__ide__executeCode",
      "Read(./.env)",
      "Read(**/.mcp.json)",
      "Write(./ecosystem/scripts)",
      "Write(.git)",
      "Write(**/package.json)",
      "Write(~/.bash_logout)",
      "Write(~/.bash_profile)",
      "Write(~/.bashrc)",
      "Write(~/.claude/hooks)",
      "Write(~/.claude/settings.json)",
      "Write(~/.claude/skills/*/_scripts)",
      "Write(~/.claude/skills/auto-approve-security)",
      "Write(~/.gitconfig)",
      "Write(~/.profile)",
      "Write(~/.zshrc)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block_dangerous_commands.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|mcp__shellicar__exec",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block_em_dashes.sh",
            "statusMessage": "Checking for em dashes..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  },
  "autoUpdatesChannel": "latest"
}